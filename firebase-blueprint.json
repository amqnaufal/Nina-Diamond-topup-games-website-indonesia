{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the application.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An order invoice for a topup.",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "userId": { "type": "string" },
        "gameName": { "type": "string" },
        "gameAccountId": { "type": "string" },
        "gameServer": { "type": "string" },
        "packageName": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceId", "userId", "gameName", "gameAccountId", "packageName", "price", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions / Invoices."
    }
  }
}
